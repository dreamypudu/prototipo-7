{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/login",
      "destination": "/"
    },
    {
      "source": "/simulator",
      "destination": "/app.html"
    },
    {
      "source": "/simulator/",
      "destination": "/app.html"
    }
  ]
}
